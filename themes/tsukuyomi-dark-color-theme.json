  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#6E85A2",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier",
        "keyword.other",
        "modifier"
      ],
      "settings": {
        "foreground": "#8FA6FF"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "keyword.operator.expression",
        "keyword.operator.new"
      ],
      "settings": {
        "foreground": "#7488A4"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic",
        "variable.function"
      ],
      "settings": {
        "foreground": "#FFA24C"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.other.inherited-class",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#FF6FC2"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#36E0D8"
      }
    },
    {
      "scope": [
        "string.regexp",
        "constant.character.escape",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#79E6B0"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.language.boolean",
        "constant.language.null"
      ],
      "settings": {
        "foreground": "#F4CF6A"
      }
    },
    {
      "scope": [
        "constant.other",
        "variable.other.constant",
        "entity.name.constant",
        "support.constant"
      ],
      "settings": {
        "foreground": "#F4CF6A"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "meta.definition.variable.name"
      ],
      "settings": {
        "foreground": "#DCE6F2"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "meta.property",
        "variable.object.property"
      ],
      "settings": {
        "foreground": "#DCE6F2"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#BFD0EC",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "variable.language",
        "variable.language.this",
        "keyword.other.this"
      ],
      "settings": {
        "foreground": "#FFA24C",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#FF6D6D"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#6FB4FF",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "support.type.property-name",
        "support.type.property-name.json",
        "meta.object-literal.key",
        "support.type.property-name.css"
      ],
      "settings": {
        "foreground": "#C9A6FF"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#627490"
      }
    },
    {
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#FF6FC2",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "support.type.primitive",
        "support.type.builtin"
      ],
      "settings": {
        "foreground": "#8FA6FF"
      }
    },
    {
      "scope": [
        "tag.css",
        "support.constant.property-value.css",
        "constant.numeric.css"
      ],
      "settings": {
        "foreground": "#F4CF6A"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#FFA24C",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#F4CF6A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#8FA6FF",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#36E0D8"
      }
    },
    {
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#79E6B0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link",
        "markup.link"
      ],
      "settings": {
        "foreground": "#6FB4FF",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#79E6B0"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#FF6D6D"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#F4CF6A"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FF6D6D",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "entity.name.label"
      ],
      "settings": {
        "foreground": "#FF6FC2"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#FFA24C",
    "method": "#FFA24C",
    "class": "#FF6FC2",
    "type": "#FF6FC2",
    "enum": "#FF6FC2",
    "interface": "#FF8FD2",
    "string": "#36E0D8",
    "number": "#F4CF6A",
    "keyword": "#8FA6FF",
    "variable": "#DCE6F2",
    "property": "#C9A6FF",
    "parameter": "#BFD0EC",
    "*.declaration": {
      "fontStyle": "bold"
    }
  }
}