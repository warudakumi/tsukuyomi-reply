  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#7A7050",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier",
        "keyword.other",
        "modifier"
      ],
      "settings": {
        "foreground": "#6B53AE"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "keyword.operator.expression",
        "keyword.operator.new"
      ],
      "settings": {
        "foreground": "#6A5F4E"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic",
        "variable.function"
      ],
      "settings": {
        "foreground": "#C9531C"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.other.inherited-class",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#C24A86"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#137F7E"
      }
    },
    {
      "scope": [
        "string.regexp",
        "constant.character.escape",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#4F8A2F"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.language.boolean",
        "constant.language.null"
      ],
      "settings": {
        "foreground": "#CE4242"
      }
    },
    {
      "scope": [
        "constant.other",
        "variable.other.constant",
        "entity.name.constant",
        "support.constant"
      ],
      "settings": {
        "foreground": "#8F680C"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "meta.definition.variable.name"
      ],
      "settings": {
        "foreground": "#3A3340"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "meta.property",
        "variable.object.property"
      ],
      "settings": {
        "foreground": "#3A3340"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#5E5544",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "variable.language",
        "variable.language.this",
        "keyword.other.this"
      ],
      "settings": {
        "foreground": "#C9531C",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#D6452C"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#2A72BE",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "support.type.property-name",
        "support.type.property-name.json",
        "meta.object-literal.key",
        "support.type.property-name.css"
      ],
      "settings": {
        "foreground": "#8F680C"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#6A5F4E"
      }
    },
    {
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#C24A86",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "support.type.primitive",
        "support.type.builtin"
      ],
      "settings": {
        "foreground": "#6B53AE"
      }
    },
    {
      "scope": [
        "tag.css",
        "support.constant.property-value.css",
        "constant.numeric.css"
      ],
      "settings": {
        "foreground": "#CE4242"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#C9531C",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#8F680C",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#6B53AE",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#137F7E"
      }
    },
    {
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#4F8A2F",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link",
        "markup.link"
      ],
      "settings": {
        "foreground": "#2A72BE",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#4F8A2F"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#C53A28"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#8F680C"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#C53A28",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "entity.name.label"
      ],
      "settings": {
        "foreground": "#C24A86"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#C9531C",
    "method": "#C9531C",
    "class": "#C24A86",
    "type": "#C24A86",
    "enum": "#C24A86",
    "interface": "#AC3F76",
    "string": "#137F7E",
    "number": "#CE4242",
    "keyword": "#6B53AE",
    "variable": "#3A3340",
    "property": "#3A3340",
    "parameter": "#5E5544",
    "*.declaration": {
      "fontStyle": "bold"
    }
  }
}